---
import Base from "../layouts/Base.astro";
import ExperimentalSidebar from "../components/ExperimentalSidebar.svelte";
---

<Base title="Experimental Sidebar" description="Preview the experimental sidebar test harness.">
	<div class="page">
		<ExperimentalSidebar client:load />
	</div>
</Base>

<style>
	:global(html),
	:global(body) {
		margin: 0;
		width: 100%;
		height: 100%;
		overflow: hidden;
	}

	.page {
		width: 100vw;
		min-height: 100vh;
		overflow: hidden;
		background: #0d1117;
		transition: background 0.15s ease;
	}

	/* follow the sidebar's theme toggle (set on <html> by the component) */
	:global(html[data-sidebar-theme="light"]) .page {
		background: #f6f8fa;
	}
</style>
